<div class="container">
       <!-- 打字机 Hero -->
    <div class="page-hero">
        <div class="hero-content">
            <div class="hero-badge"><i class="fas fa-satellite"></i> 观测站日志系统 v2.3</div>
            <h1 class="hero-title" id="typingTitle" data-text="空洞探索日志">-</h1>
            <p class="hero-desc" id="typingDesc" data-text="// ARCHIVE_INDEX :: 所有已解密观测报告的时空索引">-</p>
            <div class="hero-stats">
                <div class="hero-stat-item">
                    <div class="hero-stat-number"><%= site.posts.length %></div>
                    <div class="hero-stat-label">观测报告</div>
                </div>
                <div class="hero-stat-item">
                    <div class="hero-stat-number"><%= getYearInfo().span %></div>
                    <div class="hero-stat-label">覆盖年份</div>
                </div>
                <div class="hero-stat-item">
                    <div class="hero-stat-number"><%= site.categories.length %></div>
                    <div class="hero-stat-label">分类维度</div>
                </div>
            </div>
        </div>
        <div class="hero-decoration-line"></div>
    </div>

    <!-- 统计卡片 -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-file-alt"></i></div>
            <div class="stat-number" id="statTotal"><%= site.posts.length %></div>
            <div class="stat-label">观测报告</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-layer-group"></i></div>
            <div class="stat-number" id="statCategories"><%= site.categories.length %></div>
            <div class="stat-label">分类维度</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-tags"></i></div>
            <div class="stat-number" id="statTags"><%= site.tags.length %></div>
            <div class="stat-label">索引标签</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-clock"></i></div>
            <div class="stat-number" id="statWords"><%= total_words_formatted() %></div>
            <div class="stat-label">累计字数</div>
        </div>
    </div>

    <div class="filter-bar" id="filterBar">
        <button class="filter-btn active" data-filter="all">全部记录 <span class="count">(<%= site.posts.length %>)</span></button>
        <% site.categories.forEach(function(cat){ %>
        <button class="filter-btn" data-filter="<%= cat.name %>"><%= cat.name %> <span class="count"><%= cat.posts.length %></span></button>
        <% }) %>
    </div>

    <div class="timeline" id="timeline">
        <%
        const yearMap = getPostsGroupedByYear({ sort: 'desc', limit: 20 });
        const years = Object.keys(yearMap).sort((a, b) => b - a);
        %>
        <% years.forEach(function(year){ %>
            <div class="year-marker" data-year="<%= year %>" id="year-<%= year %>">
                <span class="year-label"><%= year %></span>
                <span class="year-count"><%= yearMap[year].length %>份观测报告</span>
            </div>
            <% yearMap[year].forEach(post => { 
                const firstCategory = post.categories && post.categories.length > 0 ? post.categories.first() : null;
                const categoryName = firstCategory ? firstCategory.name : '';
            %>
            <div class="timeline-item" data-category="<%= categoryName %>" data-year="<%= year %>">
                <a href="<%- url_for(post.path) %>" class="archive-card">
                    <div class="card-meta-row">
                        <span class="card-date">
                            <i class="far fa-calendar-alt"></i>
                            <%- date(post.date, 'YYYY.MM.DD') %>
                        </span>
                        <% if (firstCategory) { %>
                            <span class="card-category"><%= firstCategory.name %></span>
                        <% } %>
                        <span class="card-reading-time"><i class="far fa-clock"></i> <%= read_time(post.content) %> 分钟</span>
                    </div>
                    <div class="card-title"><%= post.title %></div>
                    <div class="card-excerpt"><%= post.description %></div>
                    <div class="card-tags">
                        <% post.tags.forEach(function(tag){ %>
                        <span>#<%= tag.name %></span>
                        <% }) %>
                    </div>
                </a>
            </div>
            <% }); %>
        <% }) %>
    </div>

    <div class="empty-state" id="emptyState" style="display:none;"><i class="fas fa-search"></i>
        <p>该分类下暂无观测报告</p>
        <p style="font-size:0.7rem;margin-top:4px;">信号微弱，尝试调整筛选条件</p>
    </div>
</div>

<nav class="year-nav" id="yearNav">
    <% years.forEach(function(year){ %>
        <a href="#year-<%= year %>" data-year="<%= year %>"><%= year %></a>
    <% }) %>
</nav>

<script>
(function () {
    const filterBar = document.getElementById('filterBar');
    const timeline = document.getElementById('timeline');
    const yearNav = document.getElementById('yearNav');
    if (!filterBar || !timeline || !yearNav) return;

    const items = timeline.querySelectorAll('.timeline-item');
    const yearMarkers = timeline.querySelectorAll('.year-marker');
    const navLinks = yearNav.querySelectorAll('a');
    const emptyState = document.getElementById('emptyState');

    // ========== 委托式筛选按钮 ==========
    filterBar.addEventListener('click', function(e) {
        const btn = e.target.closest('.filter-btn');
        if (!btn) return;
        e.preventDefault();
        filterBar.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilter(btn.dataset.filter);
    });

    function applyFilter(filter) {
        items.forEach(item => {
            const category = item.dataset.category || '';
            item.style.display = (filter === 'all') ? '' : (category === filter ? '' : 'none');
        });

        yearMarkers.forEach(marker => {
            const year = marker.dataset.year;
            const yearItems = timeline.querySelectorAll(`.timeline-item[data-year="${year}"]`);
            let hasVisible = false;
            yearItems.forEach(item => {
                if (item.style.display !== 'none') hasVisible = true;
            });
            marker.style.display = hasVisible ? '' : 'none';
        });

        navLinks.forEach(link => {
            const year = link.dataset.year;
            const marker = timeline.querySelector(`.year-marker[data-year="${year}"]`);
            link.style.display = (marker && marker.style.display !== 'none') ? '' : 'none';
        });

        if (emptyState) {
            const hasVisible = Array.from(items).some(item => item.style.display !== 'none');
            emptyState.style.display = hasVisible ? 'none' : 'block';
        }

        updateActiveYearFromVisible();
    }

    function updateActiveYearFromVisible() {
        let activeYear = null;
        for (const marker of yearMarkers) {
            if (marker.style.display !== 'none') {
                activeYear = marker.dataset.year;
                break;
            }
        }
        navLinks.forEach(link => {
            link.classList.toggle('active', activeYear != null && link.dataset.year === activeYear);
        });
    }

    // ========== 年份导航平滑滚动（委托） ==========
    yearNav.addEventListener('click', function(e) {
        const link = e.target.closest('a');
        if (!link) return;
        e.preventDefault();
        const target = document.getElementById(`year-${link.dataset.year}`);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // ========== Intersection Observer 激活年份 ==========
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const year = entry.target.dataset.year;
                navLinks.forEach(link => link.classList.toggle('active', link.dataset.year === year));
            }
        });
    }, { threshold: 0.5 });
    yearMarkers.forEach(marker => observer.observe(marker));

    // ========== 初始化 ==========
    applyFilter('all');

    // ========== 统计数字滚动动画（RAF 优化） ==========
    requestAnimationFrame(() => {
        document.querySelectorAll('.stat-number').forEach(el => {
            const text = el.textContent;
            const target = parseInt(text.replace(/[^\d]/g, ''), 10);
            if (isNaN(target)) return;
            const suffix = text.includes('w') ? 'w' : '';
            let current = 0;
            const step = Math.max(1, Math.floor(target / 30));
            function animate() {
                current += step;
                if (current >= target) {
                    el.textContent = target + suffix;
                } else {
                    el.textContent = current + suffix;
                    requestAnimationFrame(animate);
                }
            }
            animate();
        });
    });

    // ========== 打字机效果（RAF 代替 setTimeout） ==========
    function typeWriter(element, text, options = {}) {
        const { speed = 100, randomRange = 120, showCursor = true, onComplete = null } = options;
        if (!element || !text) return;
        element.textContent = '';
        const cursor = showCursor ? document.createElement('span') : null;
        if (cursor) {
            cursor.className = 'typing-cursor';
            element.appendChild(cursor);
        }

        let index = 0;
        let lastTime = performance.now();
        let nextDelay = speed + Math.random() * randomRange;

        function step(now) {
            if (index >= text.length) {
                if (onComplete) onComplete();
                return;
            }
            if (now - lastTime >= nextDelay) {
                const charNode = document.createTextNode(text.charAt(index));
                if (cursor) {
                    element.insertBefore(charNode, cursor);
                } else {
                    element.appendChild(charNode);
                }
                index++;
                lastTime = now;
                nextDelay = speed + Math.random() * randomRange;
            }
            requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
    }

    const titleEl = document.getElementById('typingTitle');
    const descEl = document.getElementById('typingDesc');
    const titleText = titleEl ? titleEl.dataset.text : '';
    const descText = descEl ? descEl.dataset.text : '';

    if (titleEl && titleText) {
        typeWriter(titleEl, titleText, {
            speed: 130,
            randomRange: 140,
            showCursor: false,
            onComplete: startDescLoop
        });
    } else {
        startDescLoop();
    }

    function startDescLoop() {
        if (!descEl || !descText) return;
        function runLoop() {
            typeWriter(descEl, descText, {
                speed: 100,
                randomRange: 130,
                showCursor: true,
                onComplete: () => setTimeout(runLoop, 2500)
            });
        }
        runLoop();
    }
})();
</script>